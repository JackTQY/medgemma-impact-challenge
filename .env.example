# Optional. Copy to .env; stub mode runs without this.

# Real LLM for Scribe
USE_MEDGEMMA=1
USE_MEDGEMMA_BACKEND=vertex
# USE_MEDGEMMA_BACKEND=huggingface
# USE_MEDGEMMA_BACKEND=local

# Vertex AI (backend=vertex)
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_CHAT_MODEL=gemini-2.0-flash-exp

# Hugging Face (backend=huggingface)
# HF_TOKEN=your_huggingface_token
# MEDGEMMA_HF_MODEL=google/medgemma-2-4b-it

# Local MedGemma (backend=local) — optional; 4B model ~10GB disk, needs substantial RAM/GPU
# USE_MEDGEMMA_BACKEND=local + pip install -r requirements-local.txt
# MEDGEMMA_LOCAL_MODEL=./models/medgemma-2-4b-it or google/medgemma-2-4b-it
