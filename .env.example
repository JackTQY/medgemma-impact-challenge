# Copy to .env and fill in. Do not commit .env.

# Enable real MedGemma (1/true/yes) and choose backend:
USE_MEDGEMMA=1
USE_MEDGEMMA_BACKEND=vertex
# or
# USE_MEDGEMMA_BACKEND=huggingface

# Vertex AI (GCP)
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_CHAT_MODEL=gemini-2.0-flash-exp

# Hugging Face (for MedGemma)
# HF_TOKEN=your_huggingface_token
# MEDGEMMA_HF_MODEL=google/medgemma-2-4b-it

# Kaggle (optional)
# KAGGLE_KEY=your_kaggle_api_key
