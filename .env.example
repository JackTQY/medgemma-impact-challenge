# Optional. Copy to .env; stub mode runs without this.

# Real LLM for Scribe
USE_MEDGEMMA=1
USE_MEDGEMMA_BACKEND=vertex
# USE_MEDGEMMA_BACKEND=huggingface
# USE_MEDGEMMA_BACKEND=local
# USE_MEDGEMMA_BACKEND=local_gguf

# Vertex AI (backend=vertex)
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_CHAT_MODEL=gemini-2.0-flash-exp

# Hugging Face (backend=huggingface)
# HF_TOKEN=your_huggingface_token
# MEDGEMMA_HF_MODEL=google/medgemma-4b-it

# Local MedGemma (backend=local) — optional; 4B model ~10GB disk, needs substantial RAM/GPU
# USE_MEDGEMMA_BACKEND=local + pip install -r requirements-local.txt
# MEDGEMMA_LOCAL_MODEL=./models/medgemma-1.5-4b-it or google/medgemma-4b-it

# Quantized GGUF (backend=local_gguf) — smaller download (~1.8–2.6 GB); pip install -r requirements-gguf.txt
# Run: python scripts/download_medgemma_gguf.py then set:
# MEDGEMMA_LOCAL_GGUF=models/medgemma-4b-it-gguf/medgemma-4b-it-Q4_K_M.gguf
# Optional: MEDGEMMA_GGUF_QUANT=Q2_K (smallest) | Q4_K_S | Q4_K_M (default) | Q5_K_M
